package example;

import java.util.Scanner;

public class que_6 {
	
	void prime(int n) {
		if((n%1==0 && n%n==0) ^n%2==0) {
			System.out.println("the number is prime "+n);
			
			}
		else {
			System.out.println("the number is not prime ");
		}
	}
	public static void main(String[] args){
		que_6 number=new que_6();

		number.prime(6);
		}
	

}
